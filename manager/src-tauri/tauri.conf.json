{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CCB Manager",
  "version": "1.0.0",
  "identifier": "com.ccb.manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3850",
    "beforeDevCommand": "node server.js",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CCB Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3850; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
